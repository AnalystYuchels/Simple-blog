<%- include("partials/header", { title: "Edit Post" }) %>
  
  <h2>Edit Post</h2>

  <form action="/posts/<%= posts.id %>/update" method="post">
    <input
      type="text"
      name="title"
      value="<%= post.title %>"
      required
    >

    <textarea name="content" rows="8" required><%= post.content %></textarea>

    <button type="submit">Save changes</button>
  </form>

  <a href="/">← Back to posts</a>
  
<%- include("partials/footer") %>